PORT=80
HOST=0.0.0.0
NODE_ENV=production
DATABASE_URL=postgres://prisma.PROJECT_REF:SUPABASE_DB_PASSWORD@REGION.pooler.supabase.com:5432/postgres
# Alternativa para Square Cloud caso DATABASE_URL com caracteres especiais nao chegue ao Prisma.
DATABASE_URL_BASE64=
# Alternativa com nome proprio da aplicacao caso variaveis DATABASE_* nao cheguem ao processo.
ACH_PET_DB_URL_BASE64=
# Use PRISMA_CLIENT_IDENTITY_P12_BASE64 somente se o banco exigir certificado .p12.
# Supabase normalmente nao precisa dessa variavel.
PRISMA_CLIENT_IDENTITY_P12_BASE64=
JWT_SECRET=troque-por-uma-chave-grande-e-segura
JWT_EXPIRES_IN=7d
UPLOADS_DIR=uploads
# Use CLOUDINARY_URL ou as tres variaveis separadas abaixo.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=CLOUD_NAME
CLOUDINARY_API_KEY=API_KEY
CLOUDINARY_API_SECRET=API_SECRET
CLOUDINARY_FOLDER=ach-pet-api
