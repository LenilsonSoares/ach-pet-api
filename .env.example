PORT=80
HOST=0.0.0.0
NODE_ENV=production
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/squarecloud?schema=public
# Alternativa para Square Cloud caso DATABASE_URL com caracteres especiais nao chegue ao Prisma.
DATABASE_URL_BASE64=
# Alternativa com nome proprio da aplicacao caso variaveis DATABASE_* nao cheguem ao processo.
ACH_PET_DB_URL_BASE64=
# Se o Postgres exigir certificado no Prisma v6:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/squarecloud?schema=public&sslidentity=./certs/client-identity.p12&sslpassword=SENHA_DO_P12
# Opcional: use no deploy para criar prisma/certs/client-identity.p12 sem versionar o arquivo.
PRISMA_CLIENT_IDENTITY_P12_BASE64=
JWT_SECRET=troque-por-uma-chave-grande-e-segura
JWT_EXPIRES_IN=7d
UPLOADS_DIR=uploads
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_FOLDER=ach-pet-api
