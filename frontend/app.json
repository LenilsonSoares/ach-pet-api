{
  "expo": {
    "name": "Ach Pet",
    "slug": "ach-pet",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./src/assets/logo_ach_pet_square.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/logo_ach_pet.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "android": {
      "package": "com.lenilsonsoares.achpet",
      "versionCode": 5,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/logo_ach_pet_square.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "extra": {
      "apiBaseUrl": "https://ach-pet-api.squareweb.app"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/logo_ach_pet_square.png",
          "color": "#F4A51C"
        }
      ]
    ]
  }
}
